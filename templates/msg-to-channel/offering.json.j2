{%- set apprise_tail = '","title":{* _escape_json(_body.title or "") *},"body":{* _escape_json(_body.body or "") *},"type":{* _escape_json(_body.type or "info") *},"format":{* _escape_json(_body.format or "text") *}}' -%}
{
  "capabilities": [
    "notification"
  ],
  "description": {{ description | tojson }},
  "name": "{{ channel_name }}",
  "service_type": "notification",
  "status": "{{ status | default('ready') }}",
  "tags": {{ tags | tojson }},
  "time_created": "{{ time_created | default('2026-06-19T00:00:00Z') }}",
  "upstream_access_config": {
    "apprise": {
      "access_method": "http",
      "sort_order": 1,
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": {{ ('{"urls":"' ~ apprise_url ~ apprise_tail) | tojson }}
            }
          }
        }
      }
    },
    "apprise-plus": {
      "access_method": "http",
      "sort_order": 2,
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": {{ ('{"urls":"' ~ apprise_url_plus ~ apprise_tail) | tojson }}
            }
          }
        }
      }
    }
{%- if transformer_channel_exists | default(false) %}
    ,"gateway": {
      "access_method": "http",
      {%- if gateway_api_key is defined %}
      "api_key": {{ gateway_api_key | tojson }},
      {%- endif %}
      "sort_order": 3,
      "base_url": {{ gateway_url | tojson }},
      "raw": { "request_transformer": {
        "body_transformer": { "request": { "input_format": "json", "template": {{ gateway_body_template | tojson }} } },
        "proxy_rewrite": { "headers": { "set": { "Content-Type": {{ gateway_content_type | default('application/json') | tojson }} } } }
      } }
    },
    "gateway-plus": {
      "access_method": "http",
      {%- if gateway_api_key is defined %}
      "api_key": {{ gateway_api_key | tojson }},
      {%- endif %}
      "sort_order": 4,
      "base_url": {{ gateway_url_plus | tojson }},
      "raw": { "request_transformer": {
        "body_transformer": { "request": { "input_format": "json", "template": {{ gateway_body_template | tojson }} } },
        "proxy_rewrite": { "headers": { "set": { "Content-Type": {{ gateway_content_type | default('application/json') | tojson }} } } }
      } }
    }
{%- endif %}
  }
}

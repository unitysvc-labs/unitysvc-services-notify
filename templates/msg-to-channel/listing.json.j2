{
  "currency": "USD",
  "display_name": "{{ display_name }}",
  "documents": {
    "Connectivity test": {
      "$doc_preset": {
        "name": "{{ connectivity_preset }}",
        "apprise_url": "{{ test_apprise_url | default('') }}",
        "meta": { "channels": ["apprise"] }
      }
    },
    "Python code example": {
      "$doc_preset": {
        "name": "{{ code_example_preset }}",
        "apprise_url": "{{ test_apprise_url | default('') }}",
        "meta": { "channels": ["apprise"] }
      }
    }
{%- if transformer_channel_exists | default(false) %}
    ,"Connectivity test (gateway)": { "$doc_preset": { "name": "msg_to_gateway_connectivity", "native_body": {{ gateway_test_body | tojson }}, "local_url": {{ gateway_test_local_url | tojson }}, "channel": "gateway", "meta": { "channels": ["gateway"] } } }
    ,"Python code example (gateway)": { "$doc_preset": { "name": "msg_to_gateway_code_example_py", "channel": "gateway", "meta": { "channels": ["gateway"] } } }
{%- endif %}
  },
  "list_price": {
    "channels": {
      "apprise": {
        "description": {{ apprise_price_description | default('Free — send notifications to your own channel') | tojson }},
        "price": "0",
        "type": "constant"
      },
      "apprise-plus": {
        "description": {{ apprise_plus_price_description | default('$0.001 per message — extra per-enrollment destinations') | tojson }},
        "price": "{{ plus_price | default('0.001') }}",
        "type": "constant"
      }
{%- if transformer_channel_exists | default(false) %}
,"gateway": { "description": {{ gateway_price_description | default('Free — direct to your Discord webhook (no Apprise)') | tojson }}, "price": "0", "type": "constant" }
,"gateway-plus": { "description": {{ gateway_plus_price_description | default('$0.001 per message — extra per-enrollment destinations, direct') | tojson }}, "price": "{{ plus_price | default('0.001') }}", "type": "constant" }
{%- endif %}
    },
    "default": "apprise",
    "type": "channel"
  },
  "name": "labs/{{ channel_name }}",
  "service_options": {
    "ops_testing_parameters": {{ ops_testing_parameters | tojson }}
  },
  "status": "{{ status | default('ready') }}",
  "time_created": "{{ time_created | default('2026-06-19T00:00:00Z') }}",
  "user_access_interfaces": {
    "canonical": {
      "access_method": "http",
      "base_url": "${API_GATEWAY_BASE_URL}/{% raw %}{{ service_name }}{% endraw %}"
    }
  },
  "user_parameters_schema": {{ user_parameters_schema | tojson }}
}

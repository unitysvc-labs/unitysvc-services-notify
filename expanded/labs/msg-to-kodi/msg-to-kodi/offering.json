{
  "capabilities": [
    "notification"
  ],
  "description": "Send notifications to your own Kodi/XBMC destination through the UnitySVC gateway. POST the unified message envelope {title, body, type, format}; the gateway composes an Apprise kodis:// URL from your stored secrets and delivers via apprise.unitysvc.dev. The free apprise channel uses your own stored credentials; the apprise-plus channel binds extra per-enrollment destinations via parameters. The gateway/gateway-plus channels transform the envelope directly into a Kodi JSON-RPC GUI.ShowNotification request and post it to your Kodi device (no Apprise).",
  "name": "msg-to-kodi",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "notification",
    "kodi",
    "apprise",
    "gateway"
  ],
  "time_created": "2026-06-20T00:00:00Z",
  "upstream_access_config": {
    "apprise": {
      "access_method": "http",
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"urls\":\"kodis://${ customer_secrets.KODI_HOST }\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *},\"type\":{* _escape_json(_body.type or \"info\") *},\"format\":{* _escape_json(_body.format or \"text\") *}}"
            }
          }
        }
      },
      "sort_order": 1
    },
    "apprise-plus": {
      "access_method": "http",
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"urls\":\"kodis://${ customer_secrets.{{ params.host_secret }} }\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *},\"type\":{* _escape_json(_body.type or \"info\") *},\"format\":{* _escape_json(_body.format or \"text\") *}}"
            }
          }
        }
      },
      "sort_order": 2
    },
    "gateway": {
      "access_method": "http",
      "base_url": "${ customer_secrets.KODI_BASE ?? http://kodi.local:8080 }/jsonrpc",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"jsonrpc\":\"2.0\",\"method\":\"GUI.ShowNotification\",\"params\":{\"title\":{* _escape_json(_body.title or \"\") *},\"message\":{* _escape_json(_body.body or \"\") *},\"displaytime\":12000},\"id\":1}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            }
          }
        }
      },
      "sort_order": 3
    },
    "gateway-plus": {
      "access_method": "http",
      "base_url": "${ customer_secrets.KODI_BASE ?? http://kodi.local:8080 }/jsonrpc",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"jsonrpc\":\"2.0\",\"method\":\"GUI.ShowNotification\",\"params\":{\"title\":{* _escape_json(_body.title or \"\") *},\"message\":{* _escape_json(_body.body or \"\") *},\"displaytime\":12000},\"id\":1}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            }
          }
        }
      },
      "sort_order": 4
    }
  }
}

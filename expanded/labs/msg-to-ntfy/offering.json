{
  "capabilities": [
    "notification"
  ],
  "description": "Send notifications to your own ntfy destination through the UnitySVC gateway. POST the unified message envelope {title, body, type, format}; the gateway composes an Apprise ntfy:// URL from your stored secrets and delivers via apprise.unitysvc.dev. The free apprise channel uses your own stored credentials; the apprise-plus channel binds extra per-enrollment destinations via parameters. The gateway channel skips Apprise and POSTs a native ntfy JSON payload directly to your ntfy server.",
  "name": "msg-to-ntfy",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "notification",
    "ntfy",
    "apprise",
    "gateway"
  ],
  "time_created": "2026-06-19T00:00:00Z",
  "upstream_access_config": {
    "apprise": {
      "access_method": "http",
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"urls\":\"ntfy://${ customer_secrets.NTFY_HOST }/${ customer_secrets.NTFY_TOPIC }\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *},\"type\":{* _escape_json(_body.type or \"info\") *},\"format\":{* _escape_json(_body.format or \"text\") *}}"
            }
          }
        }
      },
      "sort_order": 1
    },
    "apprise-plus": {
      "access_method": "http",
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"urls\":\"ntfy://${ customer_secrets.{{ params.host_secret }} }/${ customer_secrets.{{ params.topic_secret }} }\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *},\"type\":{* _escape_json(_body.type or \"info\") *},\"format\":{* _escape_json(_body.format or \"text\") *}}"
            }
          }
        }
      },
      "sort_order": 2
    },
    "gateway": {
      "access_method": "http",
      "base_url": "${ customer_secrets.NTFY_BASE ?? https://ntfy.sh }/${ customer_secrets.NTFY_TOPIC }",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"title\":{* _escape_json(_body.title or \"\") *},\"message\":{* _escape_json(_body.body or \"\") *},\"priority\":{* ({info=3,success=3,warning=4,failure=5})[_body.type or \"info\"] or 3 *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            }
          }
        }
      },
      "sort_order": 3
    },
    "gateway-plus": {
      "access_method": "http",
      "base_url": "${ customer_secrets.NTFY_BASE ?? https://ntfy.sh }/${ customer_secrets.{{ params.topic_secret }} }",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"title\":{* _escape_json(_body.title or \"\") *},\"message\":{* _escape_json(_body.body or \"\") *},\"priority\":{* ({info=3,success=3,warning=4,failure=5})[_body.type or \"info\"] or 3 *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            }
          }
        }
      },
      "sort_order": 4
    }
  }
}

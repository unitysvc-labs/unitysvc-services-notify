{
  "capabilities": [
    "notification"
  ],
  "description": "Send notifications to your own Pushplus destination through the UnitySVC gateway. POST the unified message envelope {title, body, type, format}; the gateway composes an Apprise pushplus:// URL from your stored secrets and delivers via apprise.unitysvc.dev. The free apprise channel uses your own stored credentials; the apprise-plus channel binds extra per-enrollment destinations via parameters. The gateway channel skips Apprise and POSTs a native Pushplus JSON payload directly to www.pushplus.plus.",
  "name": "msg-to-pushplus",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "notification",
    "pushplus",
    "apprise",
    "gateway"
  ],
  "time_created": "2026-06-20T00:00:00Z",
  "upstream_access_config": {
    "apprise": {
      "access_method": "http",
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"urls\":\"pushplus://${ customer_secrets.PUSHPLUS_TOKEN }\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *},\"type\":{* _escape_json(_body.type or \"info\") *},\"format\":{* _escape_json(_body.format or \"text\") *}}"
            }
          }
        }
      },
      "sort_order": 1
    },
    "apprise-plus": {
      "access_method": "http",
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"urls\":\"pushplus://${ customer_secrets.{{ params.token_secret }} }\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *},\"type\":{* _escape_json(_body.type or \"info\") *},\"format\":{* _escape_json(_body.format or \"text\") *}}"
            }
          }
        }
      },
      "sort_order": 2
    },
    "gateway": {
      "access_method": "http",
      "base_url": "${ customer_secrets.PUSHPLUS_BASE ?? https://www.pushplus.plus }/send",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"token\":\"${ customer_secrets.PUSHPLUS_TOKEN }\",\"title\":{* _escape_json(_body.title or \"\") *},\"content\":{* _escape_json(_body.body or \"\") *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            }
          }
        }
      },
      "sort_order": 3
    },
    "gateway-plus": {
      "access_method": "http",
      "base_url": "${ customer_secrets.PUSHPLUS_BASE ?? https://www.pushplus.plus }/send",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"token\":\"${ customer_secrets.PUSHPLUS_TOKEN }\",\"title\":{* _escape_json(_body.title or \"\") *},\"content\":{* _escape_json(_body.body or \"\") *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            }
          }
        }
      },
      "sort_order": 4
    }
  }
}

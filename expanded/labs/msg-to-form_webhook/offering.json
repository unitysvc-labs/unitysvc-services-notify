{
  "capabilities": [
    "notification"
  ],
  "description": "Send notifications to your own Form Webhook destination through the UnitySVC gateway. POST the unified message envelope {title, body, type, format}; the gateway composes an Apprise forms:// URL from your stored secrets and delivers via apprise.unitysvc.dev. The free apprise channel uses your own stored credentials; the apprise-plus channel binds extra per-enrollment destinations via parameters. The gateway / gateway-plus channels skip Apprise: the gateway transforms the envelope into an application/x-www-form-urlencoded body with a message field and POSTs it directly to your webhook URL.",
  "name": "msg-to-form_webhook",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "notification",
    "form_webhook",
    "apprise",
    "gateway"
  ],
  "time_created": "2026-06-20T00:00:00Z",
  "upstream_access_config": {
    "apprise": {
      "access_method": "http",
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"urls\":\"forms://${ customer_secrets.FORM_WEBHOOK_HOST }\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *},\"type\":{* _escape_json(_body.type or \"info\") *},\"format\":{* _escape_json(_body.format or \"text\") *}}"
            }
          }
        }
      },
      "sort_order": 1
    },
    "apprise-plus": {
      "access_method": "http",
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"urls\":\"forms://${ customer_secrets.{{ params.host_secret }} }\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *},\"type\":{* _escape_json(_body.type or \"info\") *},\"format\":{* _escape_json(_body.format or \"text\") *}}"
            }
          }
        }
      },
      "sort_order": 2
    },
    "gateway": {
      "access_method": "http",
      "base_url": "${ customer_secrets.FORM_WEBHOOK_URL ?? https://mock.unitysvc.dev/form }",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "message={* _escape_json(_body.body or \"\") *}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/x-www-form-urlencoded"
              }
            }
          }
        }
      },
      "sort_order": 3
    },
    "gateway-plus": {
      "access_method": "http",
      "base_url": "${ customer_secrets.{{ params.host_secret }} ?? https://mock.unitysvc.dev/form }",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "message={* _escape_json(_body.body or \"\") *}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/x-www-form-urlencoded"
              }
            }
          }
        }
      },
      "sort_order": 4
    }
  }
}

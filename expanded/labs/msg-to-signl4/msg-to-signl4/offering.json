{
  "capabilities": [
    "notification"
  ],
  "description": "Send notifications to your own SIGNL4 destination through the UnitySVC gateway. POST the unified message envelope {title, body, type, format}; the gateway composes an Apprise signl4:// URL from your stored secrets and delivers via apprise.unitysvc.dev. The free apprise channel uses your own stored credentials; the apprise-plus channel binds extra per-enrollment destinations via parameters. The gateway / gateway-plus transformer channels instead POST a native SIGNL4 alert payload directly to your team webhook endpoint, bypassing Apprise.",
  "name": "msg-to-signl4",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "notification",
    "signl4",
    "apprise",
    "gateway"
  ],
  "time_created": "2026-06-20T00:00:00Z",
  "upstream_access_config": {
    "apprise": {
      "access_method": "http",
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"urls\":\"signl4://${ customer_secrets.SIGNL4_SECRET }\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *},\"type\":{* _escape_json(_body.type or \"info\") *},\"format\":{* _escape_json(_body.format or \"text\") *}}"
            }
          }
        }
      },
      "sort_order": 1
    },
    "apprise-plus": {
      "access_method": "http",
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"urls\":\"signl4://${ customer_secrets.{{ params.secret_secret }} }\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *},\"type\":{* _escape_json(_body.type or \"info\") *},\"format\":{* _escape_json(_body.format or \"text\") *}}"
            }
          }
        }
      },
      "sort_order": 2
    },
    "gateway": {
      "access_method": "http",
      "base_url": "${ customer_secrets.SIGNL4_WEBHOOK_BASE ?? https://connect.signl4.com }/webhook/${ customer_secrets.SIGNL4_TOKEN }",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"Title\":{* _escape_json(_body.title or \"\") *},\"Body\":{* _escape_json(_body.body or \"\") *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            }
          }
        }
      },
      "sort_order": 3
    },
    "gateway-plus": {
      "access_method": "http",
      "base_url": "${ customer_secrets.SIGNL4_WEBHOOK_BASE ?? https://connect.signl4.com }/webhook/${ customer_secrets.{{ params.secret_secret }} }",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"Title\":{* _escape_json(_body.title or \"\") *},\"Body\":{* _escape_json(_body.body or \"\") *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            }
          }
        }
      },
      "sort_order": 4
    }
  }
}

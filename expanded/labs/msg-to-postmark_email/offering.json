{
  "capabilities": [
    "notification"
  ],
  "description": "Send notifications to your own Postmark Email destination through the UnitySVC gateway. POST the unified message envelope {title, body, type, format}; the gateway composes an Apprise postmark:// URL from your stored secrets and delivers via apprise.unitysvc.dev. The free apprise channel uses your own stored credentials; the apprise-plus channel binds extra per-enrollment destinations via parameters.",
  "name": "msg-to-postmark_email",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "notification",
    "postmark_email",
    "apprise",
    "gateway"
  ],
  "time_created": "2026-06-19T00:00:00Z",
  "upstream_access_config": {
    "apprise": {
      "access_method": "http",
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"urls\":\"postmark://${ customer_secrets.POSTMARK_EMAIL_APIKEY }:${ customer_secrets.POSTMARK_EMAIL_FROM_EMAIL }\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *},\"type\":{* _escape_json(_body.type or \"info\") *},\"format\":{* _escape_json(_body.format or \"text\") *}}"
            }
          }
        }
      },
      "sort_order": 1
    },
    "apprise-plus": {
      "access_method": "http",
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"urls\":\"postmark://${ customer_secrets.{{ params.apikey_secret }} }:${ customer_secrets.{{ params.from_email_secret }} }\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *},\"type\":{* _escape_json(_body.type or \"info\") *},\"format\":{* _escape_json(_body.format or \"text\") *}}"
            }
          }
        }
      },
      "sort_order": 2
    },
    "gateway": {
      "access_method": "http",
      "base_url": "${ customer_secrets.POSTMARK_EMAIL_BASE ?? https://api.postmarkapp.com }/email",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"From\":\"${ customer_secrets.POSTMARK_FROM_EMAIL }\",\"To\":\"${ customer_secrets.POSTMARK_TO_EMAIL }\",\"Subject\":{* _escape_json(_body.title or \"\") *},\"TextBody\":{* _escape_json(_body.body or \"\") *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json",
                "X-Postmark-Server-Token": "${ customer_secrets.POSTMARK_SERVER_TOKEN }"
              }
            }
          }
        }
      },
      "sort_order": 3
    },
    "gateway-plus": {
      "access_method": "http",
      "base_url": "${ customer_secrets.POSTMARK_EMAIL_BASE ?? https://api.postmarkapp.com }/email",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"From\":\"${ customer_secrets.POSTMARK_FROM_EMAIL }\",\"To\":\"${ customer_secrets.POSTMARK_TO_EMAIL }\",\"Subject\":{* _escape_json(_body.title or \"\") *},\"TextBody\":{* _escape_json(_body.body or \"\") *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json",
                "X-Postmark-Server-Token": "${ customer_secrets.POSTMARK_SERVER_TOKEN }"
              }
            }
          }
        }
      },
      "sort_order": 4
    }
  }
}

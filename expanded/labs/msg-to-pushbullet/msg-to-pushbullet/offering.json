{
  "capabilities": [
    "notification"
  ],
  "description": "Send notifications to your own Pushbullet destination through the UnitySVC gateway. POST the unified message envelope {title, body, type, format}; the gateway composes an Apprise pbul:// URL from your stored secrets and delivers via apprise.unitysvc.dev. The free apprise channel uses your own stored credentials; the apprise-plus channel binds extra per-enrollment destinations via parameters. The gateway channels skip Apprise and transform the envelope into a native Pushbullet v2/pushes JSON payload delivered straight to api.pushbullet.com.",
  "name": "msg-to-pushbullet",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "notification",
    "pushbullet",
    "apprise",
    "gateway"
  ],
  "time_created": "2026-06-19T00:00:00Z",
  "upstream_access_config": {
    "apprise": {
      "access_method": "http",
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"urls\":\"pbul://${ customer_secrets.PUSHBULLET_ACCESSTOKEN }\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *},\"type\":{* _escape_json(_body.type or \"info\") *},\"format\":{* _escape_json(_body.format or \"text\") *}}"
            }
          }
        }
      },
      "sort_order": 1
    },
    "apprise-plus": {
      "access_method": "http",
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"urls\":\"pbul://${ customer_secrets.{{ params.accesstoken_secret }} }\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *},\"type\":{* _escape_json(_body.type or \"info\") *},\"format\":{* _escape_json(_body.format or \"text\") *}}"
            }
          }
        }
      },
      "sort_order": 2
    },
    "gateway": {
      "access_method": "http",
      "base_url": "${ customer_secrets.PUSHBULLET_BASE ?? https://api.pushbullet.com }/v2/pushes",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"type\":\"note\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Access-Token": "${ customer_secrets.PUSHBULLET_ACCESSTOKEN }",
                "Content-Type": "application/json"
              }
            }
          }
        }
      },
      "sort_order": 3
    },
    "gateway-plus": {
      "access_method": "http",
      "base_url": "${ customer_secrets.PUSHBULLET_BASE ?? https://api.pushbullet.com }/v2/pushes",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"type\":\"note\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Access-Token": "${ customer_secrets.PUSHBULLET_ACCESSTOKEN }",
                "Content-Type": "application/json"
              }
            }
          }
        }
      },
      "sort_order": 4
    }
  }
}

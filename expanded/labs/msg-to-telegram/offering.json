{
  "capabilities": [
    "notification"
  ],
  "description": "Send notifications to your own Telegram destination through the UnitySVC gateway. POST the unified message envelope {title, body, type, format}; the gateway composes an Apprise tgram:// URL from your stored secrets and delivers via apprise.unitysvc.dev. The free apprise channel uses your own stored credentials; the apprise-plus channel binds extra per-enrollment destinations via parameters.",
  "name": "msg-to-telegram",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "notification",
    "telegram",
    "apprise",
    "gateway"
  ],
  "time_created": "2026-06-19T00:00:00Z",
  "upstream_access_config": {
    "apprise": {
      "access_method": "http",
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"urls\":\"tgram://${ customer_secrets.TELEGRAM_BOT_TOKEN }/${ customer_secrets.TELEGRAM_CHAT_ID }\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *},\"type\":{* _escape_json(_body.type or \"info\") *},\"format\":{* _escape_json(_body.format or \"text\") *}}"
            }
          }
        }
      },
      "sort_order": 1
    },
    "apprise-plus": {
      "access_method": "http",
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"urls\":\"tgram://${ customer_secrets.{{ params.bot_token_secret }} }/${ customer_secrets.{{ params.chat_id_secret }} }\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *},\"type\":{* _escape_json(_body.type or \"info\") *},\"format\":{* _escape_json(_body.format or \"text\") *}}"
            }
          }
        }
      },
      "sort_order": 2
    },
    "gateway": {
      "access_method": "http",
      "base_url": "${ customer_secrets.TELEGRAM_API_BASE ?? https://api.telegram.org }/bot${ customer_secrets.TELEGRAM_BOT_TOKEN }/sendMessage",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"chat_id\":\"${ customer_secrets.TELEGRAM_CHAT_ID }\",\"text\":{* _escape_json(((_body.title and _body.title ~= \"\") and (_body.title .. \"\\n\\n\") or \"\") .. (_body.body or \"\")) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            }
          }
        }
      },
      "sort_order": 3
    },
    "gateway-plus": {
      "access_method": "http",
      "base_url": "${ customer_secrets.TELEGRAM_API_BASE ?? https://api.telegram.org }/bot${ customer_secrets.{{ params.bot_token_secret }} }/sendMessage",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"chat_id\":\"${ customer_secrets.TELEGRAM_CHAT_ID }\",\"text\":{* _escape_json(((_body.title and _body.title ~= \"\") and (_body.title .. \"\\n\\n\") or \"\") .. (_body.body or \"\")) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            }
          }
        }
      },
      "sort_order": 4
    }
  }
}

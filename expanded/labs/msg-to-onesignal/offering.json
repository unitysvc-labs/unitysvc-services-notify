{
  "capabilities": [
    "notification"
  ],
  "description": "Send notifications to your own OneSignal destination through the UnitySVC gateway. POST the unified message envelope {title, body, type, format}; the gateway composes an Apprise onesignal:// URL from your stored secrets and delivers via apprise.unitysvc.dev. The free apprise channel uses your own stored credentials; the apprise-plus channel binds extra per-enrollment destinations via parameters.",
  "name": "msg-to-onesignal",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "notification",
    "onesignal",
    "apprise",
    "gateway"
  ],
  "time_created": "2026-06-19T00:00:00Z",
  "upstream_access_config": {
    "apprise": {
      "access_method": "http",
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"urls\":\"onesignal://${ customer_secrets.ONESIGNAL_APP }@${ customer_secrets.ONESIGNAL_APIKEY }/${ customer_secrets.ONESIGNAL_TARGETS }\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *},\"type\":{* _escape_json(_body.type or \"info\") *},\"format\":{* _escape_json(_body.format or \"text\") *}}"
            }
          }
        }
      },
      "sort_order": 1
    },
    "apprise-plus": {
      "access_method": "http",
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"urls\":\"onesignal://${ customer_secrets.{{ params.app_secret }} }@${ customer_secrets.{{ params.apikey_secret }} }/${ customer_secrets.{{ params.targets_secret }} }\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *},\"type\":{* _escape_json(_body.type or \"info\") *},\"format\":{* _escape_json(_body.format or \"text\") *}}"
            }
          }
        }
      },
      "sort_order": 2
    },
    "gateway": {
      "access_method": "http",
      "api_key": "${ customer_secrets.ONESIGNAL_APIKEY }",
      "base_url": "${ customer_secrets.ONESIGNAL_BASE ?? https://onesignal.com }/api/v1/notifications",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"app_id\":\"${ customer_secrets.ONESIGNAL_APP }\",\"included_segments\":[\"All\"],\"headings\":{\"en\":{* _escape_json(_body.title or \"\") *}},\"contents\":{\"en\":{* _escape_json(_body.body or \"\") *}}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            }
          }
        }
      },
      "sort_order": 3
    },
    "gateway-plus": {
      "access_method": "http",
      "api_key": "${ customer_secrets.ONESIGNAL_APIKEY }",
      "base_url": "${ customer_secrets.ONESIGNAL_BASE ?? https://onesignal.com }/api/v1/notifications",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"app_id\":\"${ customer_secrets.ONESIGNAL_APP }\",\"included_segments\":[\"All\"],\"headings\":{\"en\":{* _escape_json(_body.title or \"\") *}},\"contents\":{\"en\":{* _escape_json(_body.body or \"\") *}}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            }
          }
        }
      },
      "sort_order": 4
    }
  }
}

{
  "capabilities": [
    "notification"
  ],
  "description": "Send notifications to your own XML Webhook destination through the UnitySVC gateway. POST the unified message envelope {title, body, type, format}; the gateway composes an Apprise xmls:// URL from your stored secrets and delivers via apprise.unitysvc.dev. The free apprise channel uses your own stored credentials; the apprise-plus channel binds extra per-enrollment destinations via parameters. The gateway / gateway-plus channels skip Apprise: the gateway transforms the envelope into the channel-native XML body and POSTs it directly to your webhook.",
  "name": "msg-to-xml_webhook",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "notification",
    "xml_webhook",
    "apprise",
    "gateway"
  ],
  "time_created": "2026-06-20T00:00:00Z",
  "upstream_access_config": {
    "apprise": {
      "access_method": "http",
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"urls\":\"xmls://${ customer_secrets.XML_WEBHOOK_HOST }\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *},\"type\":{* _escape_json(_body.type or \"info\") *},\"format\":{* _escape_json(_body.format or \"text\") *}}"
            }
          }
        }
      },
      "sort_order": 1
    },
    "apprise-plus": {
      "access_method": "http",
      "base_url": "${ customer_secrets.APPRISE_BASE ?? https://apprise.unitysvc.dev }/notify",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"urls\":\"xmls://${ customer_secrets.{{ params.host_secret }} }\",\"title\":{* _escape_json(_body.title or \"\") *},\"body\":{* _escape_json(_body.body or \"\") *},\"type\":{* _escape_json(_body.type or \"info\") *},\"format\":{* _escape_json(_body.format or \"text\") *}}"
            }
          }
        }
      },
      "sort_order": 2
    },
    "gateway": {
      "access_method": "http",
      "base_url": "${ customer_secrets.XML_WEBHOOK_URL ?? https://mock.unitysvc.dev/xml }",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "<Notification><Version>1.0</Version><Subject>{* _body.title or \"\" *}</Subject><Message>{* _body.body or \"\" *}</Message><MessageType>{* _body.type or \"info\" *}</MessageType></Notification>"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            }
          }
        }
      },
      "sort_order": 3
    },
    "gateway-plus": {
      "access_method": "http",
      "base_url": "${ customer_secrets.{{ params.host_secret }} ?? https://mock.unitysvc.dev/xml }",
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "<Notification><Version>1.0</Version><Subject>{* _body.title or \"\" *}</Subject><Message>{* _body.body or \"\" *}</Message><MessageType>{* _body.type or \"info\" *}</MessageType></Notification>"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            }
          }
        }
      },
      "sort_order": 4
    }
  }
}

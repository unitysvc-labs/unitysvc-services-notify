{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-LINE transformer. Accepts canonical notification payloads (title/body/from) via HTTP POST and reshapes the payload into a LINE-native message before forwarding to the pre-configured webhook. No customer secrets required \u2014 the webhook URL is registered by the service operator.",
  "name": "msg-to-line",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "asia",
    "http",
    "line",
    "messaging",
    "notification",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.LINE_BASE_URL ?? https://mock.unitysvc.dev/mock/line }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"to\":${ service_secrets.TO_ID },\"messages\":[{\"type\":\"text\",\"text\":{* _escape_json(_body.title..\"\\n\\n\".._body.body) *}}]}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Authorization": "Bearer ${ secrets.LINE_API_KEY ?? test_key }",
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/v2/bot/message/push"
          }
        }
      }
    }
  }
}

{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-Pushjet transformer. Accepts canonical notification payloads (title/body/from) via HTTP POST and reshapes the payload into a Pushjet-native message before forwarding to the pre-configured webhook. No customer secrets required \u2014 the webhook URL is registered by the service operator.",
  "name": "msg-to-pushjet",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "http",
    "notification",
    "push",
    "pushjet",
    "self-hosted",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.PUSHJET_BASE_URL ?? https://mock.unitysvc.dev/mock/pushjet }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"message\":{* _escape_json(_body.body) *},\"priority\":5,\"token\":${ service_secrets.PUSHJET_TOKEN }}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/message"
          }
        }
      }
    }
  }
}

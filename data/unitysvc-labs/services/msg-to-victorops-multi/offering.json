{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-VictorOps transformer (multi-enrollment). Each enrollment targets a different VictorOps endpoint, provided by the customer via named secrets. Accepts canonical notification payloads (title/body/from) via HTTP POST and transforms them into a VictorOps-native message, and delivers it to the customer's own VictorOps endpoint.",
  "name": "msg-to-victorops-multi",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "alerting",
    "http",
    "incident",
    "notification",
    "ops",
    "transformer",
    "victorops"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ customer_secrets.{{ params.webhook_base_url_secret }} ?? http://localhost:8100/mock/victorops }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"message_type\":\"INFO\",\"entity_display_name\":{* _escape_json(_body.title) *},\"state_message\":{* _escape_json(_body.body) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "${ customer_secrets.{{ params.webhook_path_secret }} ?? /integrations/generic/{api_id}/alert/{routing_key} }"
          }
        }
      }
    }
  }
}

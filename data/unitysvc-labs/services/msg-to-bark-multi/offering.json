{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-Bark transformer (multi-enrollment). Each enrollment targets a different Bark endpoint, provided by the customer via named secrets. Accepts canonical notification payloads (title/body/from) via HTTP POST and transforms them into a Bark-native message, and delivers it to the customer's own Bark endpoint.",
  "name": "msg-to-bark-multi",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "bark",
    "http",
    "ios",
    "notification",
    "push",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ customer_secrets.{{ params.webhook_base_url_secret }} ?? http://localhost:8100/mock/bark }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"title\":{* _escape_json(_body.title) *},\"body\":{* _escape_json(_body.body) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "${ customer_secrets.{{ params.webhook_path_secret }} ?? /{device_key} }"
          }
        }
      }
    }
  }
}

{
  "capabilities": [
    "notification"
  ],
  "description": "SMTP-to-Matrix transformer. Receives email through the UnitySVC SMTP gateway, extracts title/body/from, and reshapes the payload into a Matrix-native message before forwarding to the pre-configured webhook. No customer secrets required \u2014 the webhook URL is registered by the service operator.",
  "name": "msg-to-matrix",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "chat",
    "matrix",
    "notification",
    "open-protocol",
    "self-hosted",
    "smtp",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ service_secrets.WEBHOOK_BASE_URL }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"msgtype\":\"m.text\",\"body\":{* _escape_json(_body.title..\"\n\n\".._body.body) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/_matrix/client/v3/rooms/{room}/send/m.room.message/{txn}"
          }
        }
      }
    }
  }
}

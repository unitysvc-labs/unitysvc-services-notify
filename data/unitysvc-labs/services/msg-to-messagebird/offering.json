{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-MessageBird transformer. Accepts canonical notification payloads (title/body/from) via HTTP POST and reshapes the payload into a MessageBird-native message before forwarding to the pre-configured webhook. No customer secrets required \u2014 the webhook URL is registered by the service operator.",
  "name": "msg-to-messagebird",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "http",
    "messagebird",
    "messaging",
    "notification",
    "sms",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.MESSAGEBIRD_BASE_URL ?? http://localhost:8100/mock/messagebird }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"originator\":${ service_secrets.FROM_ID },\"recipients\":[${ service_secrets.TO_PHONE }],\"body\":{* _escape_json(_body.body) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Authorization": "AccessKey ${ secrets.MESSAGEBIRD_API_KEY ?? test_key }",
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/v2/send"
          }
        }
      }
    }
  }
}

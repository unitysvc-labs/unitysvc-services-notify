{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-WhatsApp transformer (multi-enrollment). Each enrollment targets a different WhatsApp endpoint, provided by the customer via named secrets. Accepts canonical notification payloads (title/body/from) via HTTP POST and transforms them into a WhatsApp-native message, and delivers it to the customer's own WhatsApp endpoint.",
  "name": "msg-to-whatsapp-multi",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "http",
    "messaging",
    "meta",
    "notification",
    "transformer",
    "whatsapp"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ customer_secrets.{{ params.webhook_base_url_secret }} ?? https://mock.unitysvc.dev/whatsapp/v17.0/testphoneid/messages }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"messaging_product\":\"whatsapp\",\"recipient_type\":\"individual\",\"to\":${ customer_secrets.{{ params.to_phone_secret }} },\"type\":\"text\",\"text\":{\"preview_url\":false,\"body\":{* _escape_json(_body.body) *}}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Authorization": "Bearer ${ customer_secrets.{{ params.api_key_secret }} ?? test_key }",
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "${ customer_secrets.{{ params.webhook_path_secret }} ?? /v17.0/{phone_number_id}/messages }"
          }
        }
      }
    }
  }
}

{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-WhatsApp transformer. Accepts canonical notification payloads (title/body/from) via HTTP POST and reshapes the payload into a WhatsApp-native message before forwarding to the pre-configured webhook. No customer secrets required \u2014 the webhook URL is registered by the service operator.",
  "name": "msg-to-whatsapp",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "http",
    "messaging",
    "meta",
    "notification",
    "transformer",
    "whatsapp"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.WHATSAPP_BASE_URL ?? https://mock.unitysvc.dev/whatsapp/v17.0/testphoneid/messages }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"messaging_product\":\"whatsapp\",\"recipient_type\":\"individual\",\"to\":${ service_secrets.TO_PHONE },\"type\":\"text\",\"text\":{\"preview_url\":false,\"body\":{* _escape_json(_body.body) *}}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Authorization": "Bearer ${ secrets.WHATSAPP_API_KEY ?? test_key }",
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/v17.0/{phone_number_id}/messages"
          }
        }
      }
    }
  }
}

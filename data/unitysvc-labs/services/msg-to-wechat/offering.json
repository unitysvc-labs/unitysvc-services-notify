{
  "capabilities": [
    "notification"
  ],
  "description": "SMTP-to-WeChat Work transformer. Receives email through the UnitySVC SMTP gateway, extracts title/body/from, and reshapes the payload into a WeChat Work-native message before forwarding to the pre-configured webhook. No customer secrets required \u2014 the webhook URL is registered by the service operator.",
  "name": "msg-to-wechat",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "china",
    "messaging",
    "notification",
    "smtp",
    "transformer",
    "wechat",
    "workplace"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.WECHAT_BASE_URL ?? http://localhost:8100/mock/wechat }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"msgtype\":\"text\",\"text\":{\"content\":{* _escape_json(_body.title..\"\\n\\n\".._body.body) *}}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/cgi-bin/webhook/send"
          }
        }
      }
    }
  }
}

{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-SparkPost transformer. Accepts canonical notification payloads (title/body/from) via HTTP POST and reshapes the payload into a SparkPost-native message before forwarding to the pre-configured webhook. No customer secrets required \u2014 the webhook URL is registered by the service operator.",
  "name": "msg-to-sparkpost",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "email",
    "http",
    "notification",
    "sparkpost",
    "transactional",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.SPARKPOST_BASE_URL ?? https://mock.unitysvc.dev/mock/sparkpost }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"recipients\":[{\"address\":{\"email\":${ service_secrets.EMAIL_TO }}}],\"content\":{\"from\":${ service_secrets.EMAIL_FROM },\"subject\":{* _escape_json(_body.title) *},\"text\":{* _escape_json(_body.body) *}}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Authorization": "${ secrets.SPARKPOST_API_KEY ?? test_key }",
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/api/v1/transmissions"
          }
        }
      }
    }
  }
}

{
  "capabilities": [
    "notification"
  ],
  "description": "SMTP-to-ntfy transformer (multi-enrollment). Each enrollment targets a different ntfy webhook URL, provided by the customer. Receives email through the UnitySVC SMTP gateway, transforms the canonical envelope into a ntfy-native message, and delivers it to the customer's own ntfy webhook.",
  "name": "msg-to-ntfy-multi",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "notification",
    "ntfy",
    "push",
    "self-hosted",
    "smtp",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "{{ enrollment_vars.webhook_base_url }}",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"message\":{* _escape_json(_body.body) *},\"title\":{* _escape_json(_body.title) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "{{ enrollment_vars.webhook_path }}"
          }
        }
      }
    }
  }
}

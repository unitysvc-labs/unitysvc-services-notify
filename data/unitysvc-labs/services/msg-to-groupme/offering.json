{
  "capabilities": [
    "notification"
  ],
  "description": "SMTP-to-GroupMe transformer. Receives email through the UnitySVC SMTP gateway, extracts title/body/from, and reshapes the payload into a GroupMe-native message before forwarding to the pre-configured webhook. No customer secrets required \u2014 the webhook URL is registered by the service operator.",
  "name": "msg-to-groupme",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "chat",
    "groupme",
    "messaging",
    "notification",
    "smtp",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "https://api.groupme.com",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"bot_id\":${ service_secrets.BOT_ID },\"text\":{* _escape_json(_body.title..\": \".._body.body) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/v3/bots/post"
          }
        }
      }
    }
  }
}

{
  "capabilities": [
    "notification"
  ],
  "description": "SMTP-to-Feishu / Lark transformer. Accepts canonical notification payloads (title/body/from) via HTTP POST and reshapes the payload into a Feishu / Lark-native message before forwarding to the pre-configured webhook. No customer secrets required \u2014 the webhook URL is registered by the service operator.",
  "name": "msg-to-feishu",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "chat",
    "china",
    "feishu",
    "http",
    "notification",
    "transformer",
    "workplace"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.FEISHU_BASE_URL ?? https://mock.unitysvc.dev/json }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"msg_type\":\"text\",\"content\":{\"text\":{* _escape_json(_body.title..\"\\n\\n\".._body.body) *}}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/open-apis/bot/v2/hook/{key}"
          }
        }
      }
    }
  }
}

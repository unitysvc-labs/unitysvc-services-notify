{
  "capabilities": [
    "notification"
  ],
  "description": "SMTP-to-Microsoft Teams transformer (multi-enrollment). Each enrollment targets a different Microsoft Teams endpoint, provided by the customer via named secrets. Accepts canonical notification payloads (title/body/from) via HTTP POST and transforms them into a Microsoft Teams-native message, and delivers it to the customer's own Microsoft Teams endpoint.",
  "name": "msg-to-msteams-multi",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "chat",
    "http",
    "microsoft",
    "msteams",
    "notification",
    "transformer",
    "workplace"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ customer_secrets.{{ params.webhook_base_url_secret }} ?? http://localhost:8100/mock/msteams }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"@type\":\"MessageCard\",\"@context\":\"http://schema.org/extensions\",\"themeColor\":\"0076D7\",\"summary\":{* _escape_json(_body.title) *},\"sections\":[{\"activityTitle\":{* _escape_json(_body.title) *},\"activitySubtitle\":{* _escape_json(_body.from) *},\"activityText\":{* _escape_json(_body.body) *}}]}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "${ customer_secrets.{{ params.webhook_path_secret }} ?? /webhookb2/{rest} }"
          }
        }
      }
    }
  }
}

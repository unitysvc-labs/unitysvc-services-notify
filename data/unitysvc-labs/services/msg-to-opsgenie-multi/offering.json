{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-Opsgenie transformer (multi-enrollment). Each enrollment targets a different Opsgenie endpoint, provided by the customer via named secrets. Accepts canonical notification payloads (title/body/from) via HTTP POST and transforms them into a Opsgenie-native message, and delivers it to the customer's own Opsgenie endpoint.",
  "name": "msg-to-opsgenie-multi",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "alerting",
    "http",
    "incident",
    "notification",
    "ops",
    "opsgenie",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.OPSGENIE_BASE_URL ?? http://localhost:8100/mock/opsgenie }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"message\":{* _escape_json(_body.title) *},\"description\":{* _escape_json(_body.body) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Authorization": "GenieKey ${ customer_secrets.{{ params.api_key_secret }} ?? test_key }",
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/v2/alerts"
          }
        }
      }
    }
  }
}

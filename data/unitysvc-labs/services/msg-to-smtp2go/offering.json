{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-SMTP2GO transformer. Accepts canonical notification payloads (title/body/from) via HTTP POST and reshapes the payload into a SMTP2GO-native message before forwarding to the pre-configured webhook. No customer secrets required \u2014 the webhook URL is registered by the service operator.",
  "name": "msg-to-smtp2go",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "email",
    "http",
    "notification",
    "smtp2go",
    "transactional",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.SMTP2GO_BASE_URL ?? http://localhost:8100/mock/smtp2go }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"api_key\":${ service_secrets.API_KEY },\"sender\":${ service_secrets.EMAIL_FROM },\"to\":[${ service_secrets.EMAIL_TO }],\"subject\":{* _escape_json(_body.title) *},\"text_body\":{* _escape_json(_body.body) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/v3/email/send"
          }
        }
      }
    }
  }
}

{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-Resend transformer. Accepts canonical notification payloads (title/body/from) via HTTP POST and reshapes the payload into a Resend-native message before forwarding to the pre-configured webhook. No customer secrets required \u2014 the webhook URL is registered by the service operator.",
  "name": "msg-to-resend",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "email",
    "http",
    "notification",
    "resend",
    "transactional",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.RESEND_BASE_URL ?? https://mock.unitysvc.dev/mock/resend }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"from\":${ service_secrets.EMAIL_FROM },\"to\":[${ service_secrets.EMAIL_TO }],\"subject\":{* _escape_json(_body.title) *},\"text\":{* _escape_json(_body.body) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Authorization": "Bearer ${ secrets.RESEND_API_KEY ?? test_key }",
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/emails"
          }
        }
      }
    }
  }
}

{
  "capabilities": [
    "notification"
  ],
  "description": "SMTP-to-Microsoft Teams transformer. Accepts canonical notification payloads (title/body/from) via HTTP POST and reshapes the payload into a Microsoft Teams-native message before forwarding to the pre-configured webhook. No customer secrets required \u2014 the webhook URL is registered by the service operator.",
  "name": "msg-to-msteams",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "chat",
    "http",
    "microsoft",
    "msteams",
    "notification",
    "transformer",
    "workplace"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.MSTEAMS_BASE_URL ?? https://mock.unitysvc.dev/msteams/workflows/test }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"@type\":\"MessageCard\",\"@context\":\"http://schema.org/extensions\",\"themeColor\":\"0076D7\",\"summary\":{* _escape_json(_body.title) *},\"sections\":[{\"activityTitle\":{* _escape_json(_body.title) *},\"activitySubtitle\":{* _escape_json(_body.from) *},\"activityText\":{* _escape_json(_body.body) *}}]}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/webhookb2/{rest}"
          }
        }
      }
    }
  }
}

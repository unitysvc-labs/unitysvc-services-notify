{
  "capabilities": [
    "notification"
  ],
  "description": "SMTP-to-ServerChan transformer (multi-enrollment). Each enrollment targets a different ServerChan endpoint, provided by the customer via named secrets. Receives email through the UnitySVC SMTP gateway, transforms the canonical envelope into a ServerChan-native message, and delivers it to the customer's own ServerChan endpoint.",
  "name": "msg-to-serverchan-multi",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "notification",
    "push",
    "serverchan",
    "smtp",
    "transformer",
    "wechat"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ customer_secrets.{{ params.webhook_base_url_secret }} ?? http://localhost:8100/mock/serverchan }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"title\":{* _escape_json(_body.title) *},\"desp\":{* _escape_json(_body.body) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "${ customer_secrets.{{ params.webhook_path_secret }} ?? /{sendkey}.send }"
          }
        }
      }
    }
  }
}

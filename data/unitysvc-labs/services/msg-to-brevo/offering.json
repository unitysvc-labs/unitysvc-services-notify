{
  "capabilities": [
    "notification"
  ],
  "description": "SMTP-to-Brevo transformer. Receives email through the UnitySVC SMTP gateway, extracts title/body/from, and reshapes the payload into a Brevo-native message before forwarding to the pre-configured webhook. No customer secrets required \u2014 the webhook URL is registered by the service operator.",
  "name": "msg-to-brevo",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "brevo",
    "email",
    "notification",
    "smtp",
    "transactional",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.BREVO_BASE_URL ?? http://localhost:8100/mock/brevo }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"sender\":{\"email\":${ service_secrets.EMAIL_FROM }},\"to\":[{\"email\":${ service_secrets.EMAIL_TO }}],\"subject\":{* _escape_json(_body.title) *},\"textContent\":{* _escape_json(_body.body) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json",
                "api-key": "${ secrets.BREVO_API_KEY ?? test_key }"
              }
            },
            "method": "POST",
            "uri": "/v3/smtp/email"
          }
        }
      }
    }
  }
}

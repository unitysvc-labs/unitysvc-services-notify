{
  "capabilities": [
    "notification"
  ],
  "description": "SMTP-to-SIGNL4 transformer. Receives email through the UnitySVC SMTP gateway, extracts title/body/from, and reshapes the payload into a SIGNL4-native message before forwarding to the pre-configured webhook. No customer secrets required \u2014 the webhook URL is registered by the service operator.",
  "name": "msg-to-signl4",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "alerting",
    "incident",
    "mobile",
    "notification",
    "ops",
    "signl4",
    "smtp",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.SIGNL4_BASE_URL ?? http://localhost:8100/mock/signl4 }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"Title\":{* _escape_json(_body.title) *},\"Message\":{* _escape_json(_body.body) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/webhook/{token}"
          }
        }
      }
    }
  }
}

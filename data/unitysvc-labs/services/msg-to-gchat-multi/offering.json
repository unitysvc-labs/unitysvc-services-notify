{
  "capabilities": [
    "notification"
  ],
  "description": "SMTP-to-Google Chat transformer (multi-enrollment). Each enrollment targets a different Google Chat endpoint, provided by the customer via named secrets. Receives email through the UnitySVC SMTP gateway, transforms the canonical envelope into a Google Chat-native message, and delivers it to the customer's own Google Chat endpoint.",
  "name": "msg-to-gchat-multi",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "chat",
    "gchat",
    "google",
    "notification",
    "smtp",
    "transformer",
    "workplace"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ customer_secrets.{{ params.webhook_base_url_secret }} }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"text\":{* _escape_json(_body.title..\": \".._body.body) *},\"username\":{* _escape_json(_body.from) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "${ customer_secrets.{{ params.webhook_path_secret }} }"
          }
        }
      }
    }
  }
}

      "to_id_secret"
    ],
    "title": "LINE Transformer Configuration",
    "type": "object"
  },
  "user_parameters_ui_schema": {
    "api_key_secret": {
      "ui:description": "Enter the name of the customer secret holding your LINE Channel Access Token",
      "ui:placeholder": "LINE_CHANNEL_ACCESS_TOKEN"
    },
    "to_id_secret": {
      "ui:description": "Enter the name of the customer secret holding the target user or group ID",

{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-LINE transformer (multi-enrollment). Each enrollment targets a different LINE endpoint, provided by the customer via named secrets. Accepts canonical notification payloads (title/body/from) via HTTP POST and transforms them into a LINE-native message, and delivers it to the customer's own LINE endpoint.",
  "name": "msg-to-line-multi",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "asia",
    "http",
    "line",
    "messaging",
    "notification",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.LINE_BASE_URL ?? http://localhost:8100/mock/line }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"to\":${ customer_secrets.{{ params.to_id_secret }} },\"messages\":[{\"type\":\"text\",\"text\":{* _escape_json(_body.title..\"\\n\\n\".._body.body) *}}]}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Authorization": "Bearer ${ customer_secrets.{{ params.api_key_secret }} ?? test_key }",
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/v2/bot/message/push"
          }
        }
      }
    }
  }
}

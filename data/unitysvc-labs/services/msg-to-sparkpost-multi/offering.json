{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-SparkPost transformer (multi-enrollment). Each enrollment targets a different SparkPost endpoint, provided by the customer via named secrets. Accepts canonical notification payloads (title/body/from) via HTTP POST and transforms them into a SparkPost-native message, and delivers it to the customer's own SparkPost endpoint.",
  "name": "msg-to-sparkpost-multi",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "email",
    "http",
    "notification",
    "sparkpost",
    "transactional",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.SPARKPOST_BASE_URL ?? https://mock.unitysvc.dev/sparkpost/api/v1/transmissions }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"recipients\":[{\"address\":{\"email\":${ customer_secrets.{{ params.to_email_secret }} }}}],\"content\":{\"from\":${ customer_secrets.{{ params.from_email_secret }} },\"subject\":{* _escape_json(_body.title) *},\"text\":{* _escape_json(_body.body) *}}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Authorization": "${ customer_secrets.{{ params.api_key_secret }} ?? test_key }",
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/api/v1/transmissions"
          }
        }
      }
    }
  }
}

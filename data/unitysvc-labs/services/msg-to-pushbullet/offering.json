{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-Pushbullet transformer. Accepts canonical notification payloads (title/body/from) via HTTP POST and reshapes the payload into a Pushbullet-native message before forwarding to the pre-configured webhook. No customer secrets required \u2014 the webhook URL is registered by the service operator.",
  "name": "msg-to-pushbullet",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "http",
    "mobile",
    "notification",
    "push",
    "pushbullet",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.PUSHBULLET_BASE_URL ?? http://localhost:8100/mock/pushbullet }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"type\":\"note\",\"title\":{* _escape_json(_body.title) *},\"body\":{* _escape_json(_body.body) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Access-Token": "${ secrets.PUSHBULLET_API_KEY ?? test_key }",
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/v2/pushes"
          }
        }
      }
    }
  }
}

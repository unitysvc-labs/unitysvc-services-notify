{
  "capabilities": [
    "notification"
  ],
  "description": "Matrix notification relay. Forwards any HTTP POST body to the Matrix webhook URL stored in the customer secret `MATRIX_WEBHOOK_URL`. No body transformation \u2014 the customer sends the exact payload Matrix expects.",
  "name": "matrix-relay",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "chat",
    "matrix",
    "notification",
    "open-protocol",
    "relay",
    "self-hosted"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ customer_secrets.MATRIX_WEBHOOK_URL ?? https://mock.unitysvc.dev/matrix/_matrix/client/v3/rooms/!test:localhost/send/m.room.message/1 }",
      "is_active": true,
      "is_primary": true
    }
  }
}

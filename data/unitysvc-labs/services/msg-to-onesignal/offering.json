{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-OneSignal transformer. Accepts canonical notification payloads (title/body/from) via HTTP POST and reshapes the payload into a OneSignal-native message before forwarding to the pre-configured webhook. No customer secrets required \u2014 the webhook URL is registered by the service operator.",
  "name": "msg-to-onesignal",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "http",
    "mobile",
    "notification",
    "onesignal",
    "push",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.ONESIGNAL_BASE_URL ?? https://mock.unitysvc.dev/mock/onesignal }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"app_id\":${ service_secrets.ONESIGNAL_APP_ID },\"included_segments\":[\"All\"],\"headings\":{\"en\":{* _escape_json(_body.title) *}},\"contents\":{\"en\":{* _escape_json(_body.body) *}}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Authorization": "Key=${ secrets.ONESIGNAL_API_KEY ?? test_key }",
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/api/v1/notifications"
          }
        }
      }
    }
  }
}

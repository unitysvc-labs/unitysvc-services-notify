{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-Matrix transformer (multi-enrollment). Each enrollment targets a different Matrix endpoint, provided by the customer via named secrets. Accepts canonical notification payloads (title/body/from) via HTTP POST and transforms them into a Matrix-native message, and delivers it to the customer's own Matrix endpoint.",
  "name": "msg-to-matrix-multi",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "chat",
    "http",
    "matrix",
    "notification",
    "open-protocol",
    "self-hosted",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ customer_secrets.{{ params.webhook_base_url_secret }} ?? http://localhost:8100/mock/matrix }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"msgtype\":\"m.text\",\"body\":{* _escape_json(_body.title..\"\n\n\".._body.body) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "${ customer_secrets.{{ params.webhook_path_secret }} ?? /_matrix/client/v3/rooms/{room}/send/m.room.message/{txn} }"
          }
        }
      }
    }
  }
}

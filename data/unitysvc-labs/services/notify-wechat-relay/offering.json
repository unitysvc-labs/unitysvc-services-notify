{
  "capabilities": [
    "notification",
    "messaging"
  ],
  "description": "Multi-enrollment WeChat (WeCom) notification relay. Each enrollment connects a different WeChat (WeCom) account. Customers provide the secret name as a parameter, enabling multiple configurations under a single account.",
  "name": "notify-wechat-relay",
  "payout_price": {
    "description": "Pricing per notification sent",
    "percentage": "100.00",
    "type": "revenue_share"
  },
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "notify",
    "wechat",
    "relay",
    "messaging"
  ],
  "time_created": "2026-04-29T00:00:00Z",
  "upstream_access_config": {
    "Notify Worker": {
      "access_method": "http",
      "api_key": "${ customer_secrets.{{ params.corp_secret_secret }} ?? }",
      "base_url": "${NOTIFY_WORKER_BASE_URL}",
      "routing_key": {
        "channel": "wechat",
        "corp_id": "{{ params.corp_id }}",
        "agent_id": "{{ params.agent_id }}"
      }
    }
  }
}

{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-Telegram transformer (multi-enrollment). Each enrollment targets a different Telegram endpoint, provided by the customer via named secrets. Accepts canonical notification payloads (title/body/from) via HTTP POST and transforms them into a Telegram-native message, and delivers it to the customer's own Telegram endpoint.",
  "name": "msg-to-telegram-multi",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "chat",
    "http",
    "messaging",
    "notification",
    "telegram",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ customer_secrets.{{ params.webhook_base_url_secret }} ?? http://localhost:8100/mock/telegram }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"chat_id\":${ customer_secrets.{{ params.chat_id_secret }} },\"text\":{* _escape_json(_body.title..\"\\n\\n\".._body.body) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "${ customer_secrets.{{ params.webhook_path_secret }} ?? /bot{token}/sendMessage }"
          }
        }
      }
    }
  }
}

{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-MessageBird transformer (multi-enrollment). Each enrollment targets a different MessageBird endpoint, provided by the customer via named secrets. Accepts canonical notification payloads (title/body/from) via HTTP POST and transforms them into a MessageBird-native message, and delivers it to the customer's own MessageBird endpoint.",
  "name": "msg-to-messagebird-multi",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "http",
    "messagebird",
    "messaging",
    "notification",
    "sms",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.MESSAGEBIRD_BASE_URL ?? https://mock.unitysvc.dev/mock/messagebird }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"originator\":${ customer_secrets.{{ params.from_id_secret }} },\"recipients\":[${ customer_secrets.{{ params.to_phone_secret }} }],\"body\":{* _escape_json(_body.body) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Authorization": "AccessKey ${ customer_secrets.{{ params.api_key_secret }} ?? test_key }",
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/v2/send"
          }
        }
      }
    }
  }
}

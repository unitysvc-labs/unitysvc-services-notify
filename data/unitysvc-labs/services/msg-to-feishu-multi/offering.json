{
  "capabilities": [
    "notification"
  ],
  "description": "SMTP-to-Feishu / Lark transformer (multi-enrollment). Each enrollment targets a different Feishu / Lark endpoint, provided by the customer via named secrets. Accepts canonical notification payloads (title/body/from) via HTTP POST and transforms them into a Feishu / Lark-native message, and delivers it to the customer's own Feishu / Lark endpoint.",
  "name": "msg-to-feishu-multi",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "chat",
    "china",
    "feishu",
    "http",
    "notification",
    "transformer",
    "workplace"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ customer_secrets.{{ params.webhook_base_url_secret }} ?? https://mock.unitysvc.dev/json }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"msg_type\":\"text\",\"content\":{\"text\":{* _escape_json(_body.title..\"\\n\\n\".._body.body) *}}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "${ customer_secrets.{{ params.webhook_path_secret }} ?? /open-apis/bot/v2/hook/{key} }"
          }
        }
      }
    }
  }
}

{
  "capabilities": [
    "notification"
  ],
  "description": "SMTP-to-SendGrid transformer (multi-enrollment). Each enrollment targets a different SendGrid endpoint, provided by the customer via named secrets. Receives email through the UnitySVC SMTP gateway, transforms the canonical envelope into a SendGrid-native message, and delivers it to the customer's own SendGrid endpoint.",
  "name": "msg-to-sendgrid-multi",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "email",
    "notification",
    "sendgrid",
    "smtp",
    "transactional",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.SENDGRID_BASE_URL ?? http://localhost:8100/mock/sendgrid }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"personalizations\":[{\"to\":[{\"email\":${ customer_secrets.{{ params.to_email_secret }} }}]}],\"from\":{\"email\":${ customer_secrets.{{ params.from_email_secret }} }},\"subject\":{* _escape_json(_body.title) *},\"content\":[{\"type\":\"text/plain\",\"value\":{* _escape_json(_body.body) *}}]}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Authorization": "Bearer ${ customer_secrets.{{ params.api_key_secret }} ?? test_key }",
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/v3/mail/send"
          }
        }
      }
    }
  }
}

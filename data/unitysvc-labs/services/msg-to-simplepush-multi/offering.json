{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-SimplePush transformer (multi-enrollment). Each enrollment targets a different SimplePush endpoint, provided by the customer via named secrets. Accepts canonical notification payloads (title/body/from) via HTTP POST and transforms them into a SimplePush-native message, and delivers it to the customer's own SimplePush endpoint.",
  "name": "msg-to-simplepush-multi",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "http",
    "notification",
    "push",
    "simplepush",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ customer_secrets.{{ params.webhook_base_url_secret }} ?? http://localhost:8100/mock/simplepush }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"msg\":{* _escape_json(_body.title..\": \".._body.body) *},\"event\":{* _escape_json(_body.title) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "${ customer_secrets.{{ params.webhook_path_secret }} ?? /send/{key} }"
          }
        }
      }
    }
  }
}

{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-Discord transformer. Accepts canonical notification payloads (title/body/from) via HTTP POST and reshapes the payload into a Discord-native message before forwarding to the pre-configured webhook. No customer secrets required \u2014 the webhook URL is registered by the service operator.",
  "name": "msg-to-discord",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "chat",
    "discord",
    "gaming",
    "http",
    "notification",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.DISCORD_BASE_URL ?? http://localhost:8100/mock/discord }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"embeds\":[{\"title\":{* _escape_json(_body.title) *},\"description\":{* _escape_json(_body.body) *},\"footer\":{\"text\":{* _escape_json(\"from \".._body.from) *}}}]}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/api/webhooks/{id}/{token}"
          }
        }
      }
    }
  }
}

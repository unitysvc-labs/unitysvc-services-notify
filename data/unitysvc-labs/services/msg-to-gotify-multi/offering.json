{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-Gotify transformer (multi-enrollment). Each enrollment targets a different Gotify endpoint, provided by the customer via named secrets. Accepts canonical notification payloads (title/body/from) via HTTP POST and transforms them into a Gotify-native message, and delivers it to the customer's own Gotify endpoint.",
  "name": "msg-to-gotify-multi",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "gotify",
    "http",
    "notification",
    "push",
    "self-hosted",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ customer_secrets.{{ params.webhook_base_url_secret }} ?? http://localhost:8100/mock/gotify }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"message\":{* _escape_json(_body.body) *},\"title\":{* _escape_json(_body.title) *},\"priority\":5}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "${ customer_secrets.{{ params.webhook_path_secret }} ?? /message }"
          }
        }
      }
    }
  }
}

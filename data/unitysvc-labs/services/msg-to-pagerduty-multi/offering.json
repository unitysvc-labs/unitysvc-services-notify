{
  "capabilities": [
    "notification"
  ],
  "description": "SMTP-to-PagerDuty transformer (multi-enrollment). Each enrollment targets a different PagerDuty endpoint, provided by the customer via named secrets. Receives email through the UnitySVC SMTP gateway, transforms the canonical envelope into a PagerDuty-native message, and delivers it to the customer's own PagerDuty endpoint.",
  "name": "msg-to-pagerduty-multi",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "alerting",
    "incident",
    "notification",
    "ops",
    "pagerduty",
    "smtp",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "https://events.pagerduty.com",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"routing_key\":${ customer_secrets.{{ params.routing_key_secret }} },\"event_action\":\"trigger\",\"payload\":{\"summary\":{* _escape_json(_body.title) *},\"severity\":\"error\",\"source\":{* _escape_json(_body.from) *},\"custom_details\":{\"body\":{* _escape_json(_body.body) *}}}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/v2/enqueue"
          }
        }
      }
    }
  }
}

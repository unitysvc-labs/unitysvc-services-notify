{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-SIGNL4 transformer (multi-enrollment). Each enrollment targets a different SIGNL4 endpoint, provided by the customer via named secrets. Accepts canonical notification payloads (title/body/from) via HTTP POST and transforms them into a SIGNL4-native message, and delivers it to the customer's own SIGNL4 endpoint.",
  "name": "msg-to-signl4-multi",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "alerting",
    "http",
    "incident",
    "mobile",
    "notification",
    "ops",
    "signl4",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ customer_secrets.{{ params.webhook_base_url_secret }} ?? https://mock.unitysvc.dev/mock/signl4 }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"Title\":{* _escape_json(_body.title) *},\"Message\":{* _escape_json(_body.body) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "${ customer_secrets.{{ params.webhook_path_secret }} ?? /webhook/{token} }"
          }
        }
      }
    }
  }
}

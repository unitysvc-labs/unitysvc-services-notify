{
  "capabilities": [
    "notification"
  ],
  "description": "SMTP-to-ServerChan transformer. Receives email through the UnitySVC SMTP gateway, extracts title/body/from, and reshapes the payload into a ServerChan-native message before forwarding to the pre-configured webhook. No customer secrets required \u2014 the webhook URL is registered by the service operator.",
  "name": "msg-to-serverchan",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "notification",
    "push",
    "serverchan",
    "smtp",
    "transformer",
    "wechat"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.SERVERCHAN_BASE_URL ?? http://localhost:8100/mock/serverchan }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"title\":{* _escape_json(_body.title) *},\"desp\":{* _escape_json(_body.body) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/{sendkey}.send"
          }
        }
      }
    }
  }
}

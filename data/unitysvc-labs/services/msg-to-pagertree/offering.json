{
  "capabilities": [
    "notification"
  ],
  "description": "HTTP-to-PagerTree transformer. Accepts canonical notification payloads (title/body/from) via HTTP POST and reshapes the payload into a PagerTree-native message before forwarding to the pre-configured webhook. No customer secrets required \u2014 the webhook URL is registered by the service operator.",
  "name": "msg-to-pagertree",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": [
    "alerting",
    "http",
    "incident",
    "notification",
    "ops",
    "pagertree",
    "transformer"
  ],
  "time_created": "2026-06-01T00:00:00Z",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ secrets.PAGERTREE_BASE_URL ?? http://localhost:8100/mock/pagertree }",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": "{\"event_type\":\"alert\",\"title\":{* _escape_json(_body.title) *},\"description\":{* _escape_json(_body.body) *}}"
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "/integration/{token}"
          }
        }
      }
    }
  }
}

{
  "capabilities": [
    "notification"
  ],
  "description": "{{ channel_display }} notification relay. Forwards any HTTP POST body to the {{ channel_display }} webhook URL stored in the customer secret `{{ secret_env }}`. No body transformation — the customer sends the exact payload {{ channel_display }} expects.",
  "name": "{{ name }}",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": {{ tags | tojson }},
  "time_created": "{{ time_created }}",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "${ customer_secrets.{{ secret_env }} ?? https://mock.unitysvc.dev/mock/{{ channel_id }} }",
      "is_active": true,
      "is_primary": true
    }
  }
}

{
  "currency": "USD",
  "display_name": "SMTP -> {{ channel_display }} (Multi-Enrollment)",
  "documents": {
    "Connectivity test": {
      "$doc_preset": {
        "name": "transform_notify_connectivity_{{ body_type }}",
        "webhook_path": "{{ webhook_path }}"
      }
    },
    "Python code example": {
      "$doc_preset": {
        "name": "transform_notify_code_example_py_{{ body_type }}",
        "webhook_path": "{{ webhook_path }}"
      }
    },
    "cURL code example": {
      "$doc_preset": {
        "name": "transform_notify_code_example_sh_{{ body_type }}",
        "webhook_path": "{{ webhook_path }}"
      }
    }
  },
  "list_price": {
    "description": "{{ price_description }}",
    "price": "{{ price }}",
    "type": "constant"
  },
  "schema": "listing_v1",
  "service_options": {
    "ops_testing_parameters": {{ ops_testing_params | tojson }}
  },
  "status": "ready",
  "time_created": "{{ time_created }}",
  "user_access_interfaces": {
    "smtp_gateway": {
      "access_method": "smtp",
      "base_url": "${SMTP_GATEWAY_BASE_URL}",
      "routing_key": {
        "username": "{{ name }}"
      }
    }
  },
  "user_parameters_schema": {
    "description": "Configure your {{ channel_display }} endpoint for this enrollment",
    "properties": {
{% if not fixed_base_url %}
      "webhook_base_url_secret": {
        "description": "Name of the customer secret containing the base URL of your {{ channel_display }} server (e.g. https://hooks.slack.com)",
        "title": "Webhook Base URL Secret Name",
        "type": "string"
      },
      "webhook_path_secret": {
        "description": "Name of the customer secret containing the webhook path (e.g. {{ webhook_path }})",
        "title": "Webhook Path Secret Name",
        "type": "string"
      }{% if credential_params %},{% endif %}

{% endif %}
{% for cp in credential_params %}
      "{{ cp.param }}": {
        "description": "{{ cp.description }}",
        "title": "{{ cp.title }}",
        "type": "string"
      }{% if not loop.last %},{% endif %}

{% endfor %}
    },
    "required": [
{% if not fixed_base_url %}
      "webhook_base_url_secret",
      "webhook_path_secret"{% if credential_params %},{% endif %}

{% endif %}
{% for cp in credential_params %}
      "{{ cp.param }}"{% if not loop.last %},{% endif %}

{% endfor %}
    ],
    "title": "{{ channel_display }} Transformer Configuration",
    "type": "object"
  },
  "user_parameters_ui_schema": {
{% if not fixed_base_url %}
    "webhook_base_url_secret": {
      "ui:description": "Enter the name of the customer secret that holds the base URL (scheme + host) of your {{ channel_display }} webhook",
      "ui:placeholder": "MY_{{ channel_id | upper }}_BASE_URL"
    },
    "webhook_path_secret": {
      "ui:description": "Enter the name of the customer secret that holds the webhook path",
      "ui:placeholder": "MY_{{ channel_id | upper }}_PATH"
    }{% if credential_params %},{% endif %}

{% endif %}
{% for cp in credential_params %}
    "{{ cp.param }}": {
      "ui:description": "{{ cp.ui_description }}",
      "ui:placeholder": "{{ cp.default_secret }}"
    }{% if not loop.last %},{% endif %}

{% endfor %}
  }
}

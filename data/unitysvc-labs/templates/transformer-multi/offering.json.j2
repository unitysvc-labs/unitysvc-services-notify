{
  "capabilities": [
    "notification"
  ],
  "description": "SMTP-to-{{ channel_display }} transformer (multi-enrollment). Each enrollment targets a different {{ channel_display }} webhook URL, provided by the customer. Receives email through the UnitySVC SMTP gateway, transforms the canonical envelope into a {{ channel_display }}-native message, and delivers it to the customer's own {{ channel_display }} webhook.",
  "name": "{{ name }}",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": {{ tags | tojson }},
  "time_created": "{{ time_created }}",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": "{{ '{{' }} enrollment_vars.webhook_base_url {{ '}}' }}",
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": {{ lua_template | tojson }}
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"
              }
            },
            "method": "POST",
            "uri": "{{ '{{' }} enrollment_vars.webhook_path {{ '}}' }}"
          }
        }
      }
    }
  }
}

{
  "capabilities": [
    "notification"
  ],
  "description": "SMTP-to-{{ channel_display }} transformer (multi-enrollment). Each enrollment targets a different {{ channel_display }} endpoint, provided by the customer via named secrets. Receives email through the UnitySVC SMTP gateway, transforms the canonical envelope into a {{ channel_display }}-native message, and delivers it to the customer's own {{ channel_display }} endpoint.",
  "name": "{{ name }}",
  "schema": "offering_v1",
  "service_type": "notification",
  "status": "ready",
  "tags": {{ tags | tojson }},
  "time_created": "{{ time_created }}",
  "upstream_access_config": {
    "webhook": {
      "access_method": "http",
      "base_url": {% if fixed_base_url %}"${ secrets.{{ channel_id | upper }}_BASE_URL ?? https://mock.unitysvc.dev/mock/{{ channel_id }} }"{% else %}"${ customer_secrets.{{ '{{' }} params.webhook_base_url_secret {{ '}}' }} ?? https://mock.unitysvc.dev/mock/{{ channel_id }} }"{% endif %},
      "is_active": true,
      "is_primary": true,
      "raw": {
        "request_transformer": {
          "body_transformer": {
            "request": {
              "input_format": "json",
              "template": {{ lua_template | tojson }}
            }
          },
          "proxy_rewrite": {
            "headers": {
              "set": {
                "Content-Type": "application/json"{% if auth_header %},
                "{{ auth_header.name }}": "{{ auth_header.prefix }}${ customer_secrets.{{ '{{' }} params.api_key_secret {{ '}}' }} ?? test_key }"{% endif %}

              }
            },
            "method": "POST",
            "uri": {% if fixed_base_url %}"{{ webhook_path }}"{% else %}"${ customer_secrets.{{ '{{' }} params.webhook_path_secret {{ '}}' }} ?? {{ webhook_path }} }"{% endif %}
          }
        }
      }
    }
  }
}

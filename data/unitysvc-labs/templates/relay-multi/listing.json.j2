{
  "currency": "USD",
  "display_name": "{{ channel_display }} Relay (Multi-Enrollment)",
  "documents": {
    "Connectivity test": {
      "$doc_preset": {
        "name": "notify_relay_connectivity_{{ body_type }}",
        "webhook_path": "{{ webhook_path }}"
      }
    },
    "Python code example": {
      "$doc_preset": {
        "name": "notify_relay_code_example_py_{{ body_type }}",
        "webhook_path": "{{ webhook_path }}"
      }
    },
    "cURL code example": {
      "$doc_preset": {
        "name": "notify_relay_code_example_sh_{{ body_type }}",
        "webhook_path": "{{ webhook_path }}"
      }
    }
  },
  "list_price": {
    "description": "{{ price_description }}",
    "price": "{{ price }}",
    "type": "constant"
  },
  "schema": "listing_v1",
  "service_options": {
    "ops_testing_parameters": {{ ops_testing_params | tojson }}
  },
  "status": "ready",
  "time_created": "{{ time_created }}",
  "user_access_interfaces": {
    "http_gateway": {
      "access_method": "http",
      "base_url": "${API_GATEWAY_BASE_URL}/unitysvc-labs/{{ name }}"
    }
  },
  "user_parameters_schema": {
    "description": "Configure the {{ channel_display }} webhook for this enrollment",
    "properties": {
      "webhook_url_secret": {
        "description": "Name of the customer secret containing your {{ channel_display }} incoming webhook URL",
        "title": "Webhook URL Secret Name",
        "type": "string"
      }
    },
    "required": [
      "webhook_url_secret"
    ],
    "title": "{{ channel_display }} Relay Configuration",
    "type": "object"
  },
  "user_parameters_ui_schema": {
    "webhook_url_secret": {
      "ui:description": "Enter the name of the customer secret that holds your {{ channel_display }} webhook URL",
      "ui:placeholder": "{{ secret_env }}"
    }
  }
}

import os
import requests

# Environment variables set by UnitySVC after enrollment
base_url = os.environ["SERVICE_BASE_URL"]
api_key = os.environ["UNITYSVC_API_KEY"]

response = requests.post(
    f"{base_url}/send",
    headers={
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json",
    },
    json={
        "target": "room:Y2lzY29zcGFyazovL3VzL1JPT00v",  # Room ID prefixed with `room:` or email address prefixed with `email:` (e.g. `email:user@example.com`)
        "message": "Hello from UnitySVC!",
        "format": "text",
    },
)

print(response.status_code)
print(response.json())

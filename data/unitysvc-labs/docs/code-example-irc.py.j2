import os
import requests

# Environment variables set by UnitySVC after enrollment
base_url = os.environ["SERVICE_BASE_URL"]
api_key = os.environ["UNITYSVC_API_KEY"]

response = requests.post(
    f"{base_url}/send",
    headers={
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json",
    },
    json={
        "target": "#channel-name",  # IRC channel (e.g. `#myproject`) or nickname for a private message
        "message": "Hello from UnitySVC!",
        "format": "text",
    },
)

print(response.status_code)
print(response.json())

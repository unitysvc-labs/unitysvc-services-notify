import os
import sys

import httpx

# Send an email notification through the UnitySVC gateway (msg-to-email).
# POST the unified message envelope; the platform delivers it as email from
# its own domain — no SMTP server or email-provider API key required.
#   default channel : recipient = your UNITYSVC_NOTIFY_EMAIL secret (free)
#   plus channel    : recipient = the 'to' parameter of your enrollment
{% if local_testing %}
# msg-to-email is gateway-native (notify://email): there is no seller
# upstream to call in local mode, so this branch only confirms wiring.
print("sent (skipped: gateway-native notify://email, no upstream)")
sys.exit(0)
{% else %}
response = httpx.post(
    "{{ service_base_url }}",
    headers={"Authorization": f"Bearer {k}"} if (k := os.environ.get("UNITYSVC_API_KEY")) else {},
    json={
        "title": "Disk alert",
        "body": "clickhouse disk 92%",
        "type": "warning",
        "format": "text",
    },
)
response.raise_for_status()
print(f"sent (HTTP {response.status_code})")
{% endif %}
